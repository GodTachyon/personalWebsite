baseurl: "/"
locale: "en-US"
title: "A prototype website?"
theme: "hugo-paged"
ignoreFiles: ["\\.Rmd$", "\\.Rmarkdown$", "_cache$"]
footnotereturnlinkcontents: "↩"

outputs:
  home: [html, rss, json]

menu:
  main:
    - name: Github
      url: "https://github.com/GodTachyon"
      weight: 10
      params:
        class: [optional]

params:
  description: "A website built through Hugo with the hugo-paged theme."
  logo:
    en:
      alt: LOGO TEXT FOR NOW
      img: # a path to the logo
  footer: "[Aswath Ashok](https://github.com/GodTachyon) {Year}"

security:
  allowContent: ['.*']

markup:
  highlight:
    codeFences: false
  goldmark:
    renderer:
      unsafe: true
